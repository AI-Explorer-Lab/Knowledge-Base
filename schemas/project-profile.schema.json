{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-profile.schema.json",
  "type": "object",
  "required": ["schema_version", "project", "team_knowledge", "promotion"],
  "properties": {
    "schema_version": {"const": 1},
    "project": {
      "type": "object",
      "required": ["id", "name", "repository", "knowledge_path"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "name": {"type": "string", "minLength": 1},
        "repository": {"type": "string", "minLength": 1},
        "knowledge_path": {"const": "docs/knowledge"}
      },
      "additionalProperties": false
    },
    "team_knowledge": {
      "type": "object",
      "required": ["repository", "catalog", "enabled"],
      "properties": {
        "repository": {"type": "string", "minLength": 1},
        "catalog": {"const": "knowledge-catalog.md"},
        "enabled": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "promotion": {
      "type": "object",
      "required": ["tech_target", "biz_target"],
      "properties": {
        "tech_target": {"const": "tech-wiki"},
        "biz_target": {"const": "biz-wiki"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
