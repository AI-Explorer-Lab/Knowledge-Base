{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence.schema.json",
  "type": "object",
  "required": ["schema_version", "knowledge_id", "events"],
  "properties": {
    "schema_version": {"const": 1},
    "knowledge_id": {"type": "string"},
    "events": {"type": "array", "items": {"$ref": "#/$defs/event"}}
  },
  "$defs": {
    "event": {
      "type": "object",
      "required": ["event_id", "event_type", "occurred_at", "contributor"],
      "properties": {
        "event_id": {"type": "string", "minLength": 1},
        "event_type": {"enum": ["referenced", "adopted", "validated_success", "validated_failure", "not_applicable", "contradiction_found", "review_completed", "deprecated", "archived", "event_correction", "event_revoked"]},
        "occurred_at": {"type": "string", "format": "date-time"},
        "contributor": {"type": "string", "minLength": 1},
        "supersedes_event_id": {"type": "string"},
        "revokes_event_id": {"type": "string"}
      },
      "allOf": [{"if": {"properties": {"event_type": {"enum": ["validated_success", "validated_failure"]}}}, "then": {"required": ["project", "scenario_id", "evidence_group_id", "validation_method", "result_summary", "reference"]}}],
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
